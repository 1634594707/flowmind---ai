# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=flowmind
DATABASE_PASSWORD=flowmind123
DATABASE_NAME=flowmind
DATABASE_SSL=false

# Connection Pool
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2

# JWT Authentication
JWT_SECRET=flowmind-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=flowmind-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Redis Cache and Pub/Sub
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# DeepSeek API (Required for AI features)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.7

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# GitHub OAuth (Optional, for GitHub integration)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# OpenAI (Optional, alternative to DeepSeek)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# CORS
CORS_ORIGIN=http://localhost:5173
